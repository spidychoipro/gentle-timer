{
  "expo": {
    "name": "Gentle Timer",
    "slug": "gentle-timer",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "automatic",
    "scheme": "gentle-timer",
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.gentletimer.app"
    },
    "android": {
      "adaptiveIcon": {
        "backgroundColor": "#E6F4FE",
        "foregroundImage": "./assets/android-icon-foreground.png",
        "backgroundImage": "./assets/android-icon-background.png",
        "monochromeImage": "./assets/android-icon-monochrome.png"
      },
      "package": "com.gentletimer.app",
      "permissions": ["VIBRATE"],
      "versionCode": 1
    },
    "web": {
      "favicon": "./assets/favicon.png",
      "bundler": "metro"
    },
    "plugins": [
      "expo-router",
      "expo-system-ui",
      [
        "expo-font",
        {
          "fonts": []
        }
      ]
    ],
    "extra": {
      "router": {},
      "eas": {
        "projectId": "9def41b9-92cb-48ce-ba13-7694505867fb"
      }
    },
    "owner": "spidychoi",
    "updates": {
      "fallbackToCacheTimeout": 0,
      "url": "https://u.expo.dev/9def41b9-92cb-48ce-ba13-7694505867fb"
    },
    "runtimeVersion": {
      "policy": "sdkVersion"
    }
  }
}
